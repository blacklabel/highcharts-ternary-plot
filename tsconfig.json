{
  "compilerOptions": {
    "target": "ES6",
    "module": "es6",
    "moduleResolution": "bundler",
    "outDir": ".cache/tmp",
    "rootDir": "./ts",
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "ts/**/*"
  ],
  "exclude": [
    "node_modules",
    "js",
    "css",
    "docs",
    ".cache",
    "tests"
  ]
}
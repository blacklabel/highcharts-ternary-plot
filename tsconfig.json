{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES2015",
    "moduleResolution": "Node",
    "outDir": ".cache/tmp",
    "rootDir": "./ts",
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "ts/**/*",
    "ts/HighchartsConfig.d.ts"
  ],
  "exclude": [
    "node_modules",
    "js",
    "css",
    "docs",
    ".cache"
  ]
}